# Application
APP_NAME=AI Resume Analyzer API
APP_ENV=development
DEBUG=true

# CORS — comma-separated list of allowed origins.
# Local dev: keep localhost entries.
# Production (Render): set to your Vercel frontend URL only.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# Authentication
# Local dev: the default SQLite file just works. Production (Render free tier has NO persistent
# disk): set this to a hosted Postgres URL (e.g. Neon, Supabase, or Render's own Postgres free
# tier) or every registered user is wiped on the next redeploy/restart.
DATABASE_URL=sqlite:///./resume_analyzer.db
# REQUIRED in production — generate a long random value (e.g. `openssl rand -hex 32`) and set it
# in the Render dashboard. The default below is dev-only and NOT secure: anyone who reads this
# file could forge valid login tokens against a deployment still using it.
JWT_SECRET_KEY=dev-only-insecure-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Azure OpenAI — required for the resume analysis, company recommendation, and interview
# prep agents. All values are available in your Azure portal under the deployment details.
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=your-gpt-4-1-deployment-name
# Required for company interview-prep RAG (embeds the company knowledge base into FAISS).
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=your-embeddings-deployment-name
