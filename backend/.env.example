# Application
APP_NAME=AI Resume Analyzer API
APP_ENV=development
DEBUG=true

# CORS — comma-separated list of allowed origins.
# Local dev: keep localhost entries.
# Production (Render): set to your Vercel frontend URL only.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# Azure OpenAI — required for Phase 2 resume analysis agent.
# All values are available in your Azure portal under the deployment details.
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=your-gpt-4-1-deployment-name
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=your-embeddings-deployment-name
